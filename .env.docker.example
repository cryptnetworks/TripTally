NODE_ENV=production
DATABASE_URL=file:/app/data/triptally.db
COMPOSE_PROFILES=cloudflare
DOMAIN=app.example.com
NEXTAUTH_URL=https://app.example.com
AUTH_URL=https://app.example.com
PUBLIC_APP_URL=https://app.example.com
NEXTAUTH_SECRET=generate-a-long-random-secret-before-running-docker
TOKEN_DIGEST_SECRET=generate-a-long-random-secret-before-running-docker
AUTH_CONFIG_ENCRYPTION_KEY=generate-a-long-random-secret-before-running-docker
LETSENCRYPT_EMAIL=admin@example.com
CERTBOT_STAGING=1
DNS_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
EMAIL_APP_NAME="Trip Tally"
PASSWORD_RESET_TOKEN_MINUTES=45
RECEIPT_UPLOAD_ENABLED=false
RECEIPT_UPLOAD_DIR=/app/data/uploads/receipts
MAX_RECEIPT_UPLOAD_MB=10
ITEM_LOOKUP_ENABLED=false
ITEM_LOOKUP_PROVIDER=mock
ITEM_LOOKUP_CACHE_TTL_SECONDS=3600
AMAZON_API_KEY=
AMAZON_ASSOCIATE_TAG=
WALMART_API_KEY=
TARGET_API_KEY=
APP_BASE_URL=https://app.example.com
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=
