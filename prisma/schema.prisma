generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                           String                   @id @default(cuid())
  username                     String                   @unique
  email                        String                   @unique
  passwordHash                 String
  role                         String                   @default("user")
  disabledAt                   DateTime?
  lastLoginAt                  DateTime?
  emailVerifiedAt              DateTime?
  twoFactorMethod              String                   @default("none")
  authenticatorEnabled         Boolean                  @default(false)
  authenticatorSecretEncrypted String?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  trips                        Trip[]
  tripMemberships              TripMember[]
  participantProfiles          Participant[]
  expensesCreated              Expense[]                @relation("ExpenseCreator")
  expensesPaid                 Expense[]                @relation("ExpensePaidByUser")
  expensesUpdated              Expense[]                @relation("ExpenseUpdater")
  paymentMethods               PaymentMethod[]
  receiptsUploaded             Receipt[]                @relation("ReceiptUploader")
  discordAccount               DiscordAccount?
  discordLinkTokens            DiscordLinkToken[]
  passwordResetTokens          PasswordResetToken[]
  emailVerificationTokens      EmailVerificationToken[]
  twoFactorChallenges          TwoFactorChallenge[]
  authAccounts                 UserAuthAccount[]
  oauthLoginTokens             OAuthLoginToken[]
  auditLogs                    AuditLog[]               @relation("AuditActor")

  @@index([role])
  @@index([disabledAt])
  @@map("users")
}

model UserAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  providerId        String
  providerAccountId String
  email             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, providerAccountId])
  @@unique([userId, providerId])
  @@index([userId])
  @@map("user_auth_accounts")
}

model AuthProviderConfig {
  id                    String   @id
  name                  String
  enabled               Boolean  @default(false)
  clientId              String?
  encryptedClientSecret String?
  scopesJson            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("auth_provider_configs")
}

model OAuthLoginToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("oauth_login_tokens")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  tripId       String?
  action       String
  targetType   String
  targetId     String?
  entityType   String?
  entityId     String?
  beforeJson   String?
  afterJson    String?
  metadataJson String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  trip         Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([tripId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model TwoFactorChallenge {
  id        String    @id @default(cuid())
  codeHash  String
  method    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("two_factor_challenges")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Trip {
  id           String        @id @default(cuid())
  name         String
  destination  String?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ownerId      String
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members      TripMember[]
  participants Participant[]
  expenses     Expense[]
  receipts     Receipt[]
  auditLogs    AuditLog[]

  @@index([ownerId])
  @@map("trips")
}

model TripMember {
  id        String   @id @default(cuid())
  role      String   @default("member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tripId    String
  userId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
  @@index([tripId, role])
  @@map("trip_members")
}

model Participant {
  id            String                       @id @default(cuid())
  name          String
  email         String?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  tripId        String
  userId        String?
  trip          Trip                         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user          User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  expensesPaid  Expense[]                    @relation("ExpensePayer")
  shares        ExpenseShare[]
  receiptSplits ReceiptLineItemParticipant[]

  @@index([tripId])
  @@index([userId])
  @@map("participants")
}

model Expense {
  id              String         @id @default(cuid())
  title           String
  amount          Decimal
  category        String
  date            DateTime
  notes           String?
  status          String         @default("submitted")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  payerId         String
  tripId          String
  createdByUserId String?
  paidByUserId    String?
  updatedByUserId String?
  payer           Participant    @relation("ExpensePayer", fields: [payerId], references: [id], onDelete: Cascade)
  trip            Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy       User?          @relation("ExpenseCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  paidByUser      User?          @relation("ExpensePaidByUser", fields: [paidByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?          @relation("ExpenseUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  shares          ExpenseShare[]
  receipts        Receipt[]

  @@index([tripId])
  @@index([payerId])
  @@index([createdByUserId])
  @@index([paidByUserId])
  @@index([updatedByUserId])
  @@index([tripId, status])
  @@map("expenses")
}

model PaymentMethod {
  id         String   @id @default(cuid())
  provider   String
  label      String?
  handle     String?
  url        String?
  visibility String   @default("trip_members")
  notes      String?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@map("payment_methods")
}

model Receipt {
  id               String            @id @default(cuid())
  originalFilename String
  storedFilename   String
  storedPath       String
  mimeType         String
  fileSize         Int
  merchant         String?
  receiptDate      DateTime?
  subtotal         Decimal?
  tax              Decimal?
  tip              Decimal?
  total            Decimal?
  parserProvider   String            @default("local-heuristic")
  parserConfidence Float             @default(0)
  rawText          String?
  parsedJson       String?
  status           String            @default("needs_review")
  splitMode        String            @default("simple")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tripId           String
  expenseId        String?
  uploaderUserId   String
  trip             Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expense          Expense?          @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  uploader         User              @relation("ReceiptUploader", fields: [uploaderUserId], references: [id], onDelete: Cascade)
  lineItems        ReceiptLineItem[]

  @@index([tripId])
  @@index([expenseId])
  @@index([uploaderUserId])
  @@index([tripId, status])
  @@map("receipts")
}

model ReceiptLineItem {
  id           String                       @id @default(cuid())
  name         String
  quantity     Decimal                      @default(1)
  unitPrice    Decimal?
  totalPrice   Decimal
  category     String?
  notes        String?
  splitMethod  String                       @default("equal")
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  receiptId    String
  receipt      Receipt                      @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  participants ReceiptLineItemParticipant[]

  @@index([receiptId])
  @@map("receipt_line_items")
}

model ReceiptLineItemParticipant {
  id            String          @id @default(cuid())
  role          String
  lineItemId    String
  participantId String
  lineItem      ReceiptLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  participant   Participant     @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([lineItemId, participantId, role])
  @@index([participantId])
  @@map("receipt_line_item_participants")
}

model RetailerLookupCache {
  id         String   @id @default(cuid())
  provider   String
  query      String
  externalId String?
  resultJson String
  error      String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([provider, query, externalId])
  @@index([expiresAt])
  @@map("retailer_lookup_cache")
}

model DiscordAccount {
  id              String   @id @default(cuid())
  discordUserId   String   @unique
  discordUsername String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("discord_accounts")
}

model DiscordLinkToken {
  id              String    @id @default(cuid())
  tokenHash       String    @unique
  discordUserId   String
  discordUsername String?
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([discordUserId])
  @@index([expiresAt])
  @@map("discord_link_tokens")
}

model ExpenseShare {
  id            String      @id @default(cuid())
  shareAmount   Decimal
  expenseId     String
  participantId String
  expense       Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([expenseId, participantId])
  @@index([participantId])
  @@map("expense_shares")
}
