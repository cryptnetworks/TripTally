DATABASE_URL=file:./dev.db
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH_CONFIG_ENCRYPTION_KEY=replace-with-a-long-random-secret
NODE_ENV=development

# Production reverse proxy / Let's Encrypt DNS-01 settings.
# Compose deployment mode. Leave empty for private app only.
# Use COMPOSE_PROFILES=nginx for Nginx/Certbot.
# Use COMPOSE_PROFILES=cloudflare for Cloudflare Tunnel.
COMPOSE_PROFILES=
DOMAIN=app.example.com
LETSENCRYPT_EMAIL=admin@example.com
CERTBOT_STAGING=1
DNS_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=

# Cloudflare Tunnel deployment mode.
# In Cloudflare Zero Trust, configure app.example.com -> http://triptally:3000.
CLOUDFLARE_TUNNEL_TOKEN=

# Password reset email via SMTP. Providers such as Resend, Postmark, Mailgun,
# SendGrid, and many hosts expose SMTP credentials.
# Leave SMTP_ENABLED=false to keep email delivery disabled.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
EMAIL_APP_NAME="Trip Tally"
PASSWORD_RESET_TOKEN_MINUTES=45

# PostgreSQL-ready Prisma note:
# For production, switch the datasource provider in prisma/schema.prisma
# to "postgresql" and use a PostgreSQL connection string here.

# Docker SQLite example:
# DATABASE_URL=file:/app/data/triptally.db
