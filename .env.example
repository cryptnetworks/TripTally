# Runtime
NODE_ENV=development
DATABASE_URL=file:./dev.db

# Public app URLs. Use the same public HTTPS origin for production.
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

# Required secrets. Replace with separate values from: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret
TOKEN_DIGEST_SECRET=replace-with-a-long-random-secret
AUTH_CONFIG_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Docker deployment profile. Leave empty for private app only.
# Supported values: nginx, cloudflare
COMPOSE_PROFILES=
DOMAIN=app.example.com

# Nginx / Let's Encrypt DNS-01.
LETSENCRYPT_EMAIL=admin@example.com
CERTBOT_STAGING=1
DNS_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=

# Cloudflare Tunnel. Configure the public hostname to http://triptally:3000.
CLOUDFLARE_TUNNEL_TOKEN=

# SMTP for verification, password reset, and email MFA.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
EMAIL_APP_NAME="Trip Tally"
PASSWORD_RESET_TOKEN_MINUTES=45

# Docker SQLite example:
# DATABASE_URL=file:/app/data/triptally.db
