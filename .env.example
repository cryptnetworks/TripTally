# Runtime
NODE_ENV=development
DATABASE_URL=file:./dev.db

# Public app URLs. Use the same public HTTPS origin for production.
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

# Required secrets. Replace with separate values from: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret
TOKEN_DIGEST_SECRET=replace-with-a-long-random-secret
AUTH_CONFIG_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Docker deployment profile. Leave empty for private app only.
# Supported values: nginx, cloudflare
COMPOSE_PROFILES=
DOMAIN=app.example.com

# Nginx / Let's Encrypt DNS-01.
LETSENCRYPT_EMAIL=admin@example.com
CERTBOT_STAGING=1
DNS_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=

# Cloudflare Tunnel. Configure the public hostname to http://seddleup:3000.
CLOUDFLARE_TUNNEL_TOKEN=

# SMTP for verification, password reset, and email MFA.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
EMAIL_APP_NAME="SeddleUp"
PASSWORD_RESET_TOKEN_MINUTES=45

# Local receipt upload storage.
RECEIPT_UPLOAD_ENABLED=false
RECEIPT_UPLOAD_DIR=uploads/receipts
MAX_RECEIPT_UPLOAD_MB=10

# Retail item lookup. Real providers are disabled unless credentials are configured.
ITEM_LOOKUP_ENABLED=false
ITEM_LOOKUP_PROVIDER=mock
ITEM_LOOKUP_CACHE_TTL_SECONDS=3600
AMAZON_API_KEY=
AMAZON_ASSOCIATE_TAG=
WALMART_API_KEY=
TARGET_API_KEY=

# Discord interactions and command registration.
APP_BASE_URL=http://localhost:3000
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=

# Docker SQLite example:
# DATABASE_URL=file:/app/data/seddleup.db
